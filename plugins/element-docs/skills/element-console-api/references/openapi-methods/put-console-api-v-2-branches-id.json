{
  "slug": "put-console-api-v-2-branches-id",
  "api": {
    "tags": [
      "Групповая разработка. Ветки"
    ],
    "description": "Изменить ветку",
    "operationId": "put-console-api-v2-branches-id",
    "parameters": [
      {
        "name": "id",
        "description": "Идентификатор ссылки",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      {
        "name": "include",
        "in": "query",
        "description": "Имена атрибутов ветки, которые будут выгружены в ответе, в дополнение к основным. Через \",\". По умолчанию не выгружаются.",
        "required": false,
        "example": "?include=project,application",
        "schema": {
          "type": "string",
          "enum": [
            "project",
            "description",
            "branches",
            "applications",
            "attachments",
            "labels",
            "reviewers"
          ]
        }
      },
      {
        "name": "exclude",
        "in": "query",
        "description": "Аналогично \"include\", только указываются имена атрибутов, которые будут пропущены. Позволяет исключать любые атрибуты, в т.ч. основные. Совместим с \"include\".",
        "required": false,
        "example": "?exclude=repository,version-stamp&include=project,application",
        "schema": {
          "type": "string",
          "enum": [
            "имя-атрибута"
          ]
        }
      }
    ],
    "requestBody": {
      "description": "Данные ветки. Если атрибут не передаётся, то заполняется значением по умолчанию, в соответствии с внутренней схемой (как при интерактивной работе).",
