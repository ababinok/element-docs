{
  "slug": "post-console-api-v-2-issues",
  "api": {
    "tags": [
      "Групповая разработка. Задачи"
    ],
    "description": "Создать новую задачу",
    "operationId": "post-console-api-v2-issues",
    "parameters": [
      {
        "name": "number, title, external-url",
        "in": "query",
        "description": "Параметры поиска ссылки на задачу. Для предварительной проверки уже созданной, по естественным идентификаторам.",
        "required": false,
        "schema": {
          "type": "string"
        }
      },
      {
        "name": "project-id, project-name, project-prefix",
        "in": "query",
        "description": "Параметры поиска ссылки на проект. Для уточнения фильтра поиска ссылки на задачу и заполнения соответствующего реквизита. Допускается указание в параметрах и/или теле запроса (найти задачу в одном проекте и записать в другой).",
        "required": false,
        "schema": {
          "type": "string"
        }
      },
      {
        "name": "space-id",
        "in": "query",
        "description": "Идентификатор пространства. При работе в облаке. Для уточнения фильтра поиска ссылок по значениям естественных идентификаторов. Распространяется на значения в параметрах запроса и атрибутах тела.",
        "required": false,
        "schema": {
          "type": "string"
        }
      },
      {
        "name": "include",
        "in": "query",
        "description": "Имена атрибутов задачи, которые будут выгружены в ответе, в дополнение к основным. Через \",\". По умолчанию не выгружаются.",
        "required": false,
        "example": "?include=branches,description",
        "schema": {
          "type": "string",
          "enum": [
            "project",
            "description",
            "branches",
            "applications",
            "attachments",
            "labels",
            "reviewers"
          ]
        }
      },
      {
        "name": "exclude",
        "in": "query",
        "description": "Аналогично \"include\", только указываются имена атрибутов, которые будут пропущены. Позволяет исключать любые атрибуты, в т.ч. основные. Совместим с \"include\".",
        "required": false,
        "example": "?exclude=version-stamp,number&include=branches,description",
        "schema": {
          "type": "string",
          "enum": [
            "имя-атрибута"
          ]
        }
      },
      {
        "name": "node",
        "in": "query",
        "description": "Идентификатор внешней системы (узел-отправитель). При использовании настройки регистрации изменений для задач и нескольких систем-отправителей (узлов). Чтобы свои изменения не выгружались, при получении задач с параметром time-stamp.",
        "required": false,
        "schema": {
          "type": "string",
          "maxLength": 36,
          "default": 1
        }
      }
    ],
    "requestBody": {
      "description": "Данные задачи. Если атрибут не передаётся, то заполняется значением по умолчанию, в соответствии с внутренней схемой (как при интерактивной работе).",
      "content": {
        "application/json": {
          "schema": {
            "type": "object",
            "description": "Задача",
            "required": [
              "title"
            ],
            "properties": {
              "id": {
                "type": "string",
                "description": "Идентификатор задачи",
                "readOnly": true,
                "example": "0193dde1-d10b-7c3a-a0eb-4a0ba0319908"
              },
              "number": {
                "description": "Номер задачи. Обеспечивает контроль уникальности в пределах проекта. Если не указан при загрузке, то заполняется внутренним кодом.",
                "type": "string",
                "maxLength": 30,
                "default": "Внутренний код (ПрефиксПроекта-N)",
                "example": "CRM-1"
              },
              "title": {
                "type": "string",
                "description": "Название задачи",
                "maxLength": 150,
                "example": "Разработать API для задач"
              },
              "project": {
                "description": "Проект",
                "oneOf": [
                  {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string",
                        "description": "Идентификатор ссылки",
                        "example": "0193dde1-d10b-7c3a-a0eb-4a0ba0319908"
                      },
                      "name": {
                        "type": "string",
                        "description": "Название",
                        "example": "Управление заказами"
                      },
                      "prefix": {
                        "type": "string",
                        "description": "Префикс",
                        "example": "CRM"
                      }
                    },
                    "title": "ProjectRefDto"
                  },
                  {
                    "writeOnly": true,
                    "description": "id или name ссылки (только для записи)",
                    "type": "string",
                    "title": "IdOrNameString"
                  }
                ]
              },
              "external-url": {
                "type": "string",
                "description": "Внешний идентификатор задачи для гиперссылки. Полный URL или часть (UUID) для подстановки в шаблон.",
                "example": "http://1Cbase/issue/CRM-1"
              },
              "status": {
                "type": "string",
                "description": "Статус задачи",
                "enum": [
                  "open",
                  "in-progress",
                  "under-review",
                  "done",
                  "closed"
                ],
                "default": "open",
                "example": "in-progress"
              },
              "description": {
                "type": "string",
                "description": "Описание задачи. В формате HTML. При превышении 500 символов в свойствах задачи не выгружается (пустое значение и description-is-too-large: true). Требуется отдельная подгрузка (из .../issues/{key}/description), аналогично вложениям.",
                "example": "<body><p>Текст описания</p></body>"
              },
              "description-is-too-large": {
                "type": "boolean",
                "description": "Признак превышения объема description.",
                "default": false,
                "readOnly": true
              },
              "created": {
                "description": "Дата создания. \nДля выгрузки: можно изменить формат в настройках групповой разработки для проекта. По умолчанию — в универсальном формате с часовым поясом.\nДля загрузки: принимаются основные форматы по ISO-8601. Если в значении не указан часовой пояс, он берется из настроек групповой разработки проекта.\n",
                "type": "string",
                "format": "instant, dateTime",
                "example": "2025-01-02T10:11:12.345Z | 2025-01-02T10:11:12Z | 2025-01-02 10:11:12+03:00 | 2025-01-02 10:11:12",
                "default": "текущая дата"
              },
              "completed": {
                "description": "Дата завершения (выполнения, закрытия, удаления). Формат аналогичен \"created\".",
                "type": "string",
                "format": "instant, dateTime",
                "example": "2025-01-02T10:11:12.345Z",
                "default": "текущая дата (при записи соответствующего состояния)"
              },
              "updated": {
                "description": "Дата последнего обновления из внешней системы. Формат аналогичен \"created\".",
                "type": "string",
                "format": "instant, dateTime",
                "example": "2025-01-02T10:11:12.345Z",
                "default": "текущая дата"
              },
              "imported": {
                "description": "Дата загрузки задачи из внешней системы. Для созданных локально — пустое значение. Формат аналогичен \"created\".",
                "type": "string",
                "format": "instant, dateTime",
                "readOnly": true,
                "example": "2025-01-02T10:11:12.345Z",
                "default": "текущая дата"
              },
              "author": {
                "description": "Создатель задачи",
                "oneOf": [
                  {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string",
                        "description": "Идентификатор ссылки",
                        "example": "0193dde1-d10b-7c3a-a0eb-4a0ba0319908"
                      },
                      "name": {
                        "type": "string",
                        "description": "Имя",
                        "example": "Масков И.Р."
                      }
                    },
                    "title": "UserRefDto"
                  },
                  {
                    "writeOnly": true,
                    "description": "id или name ссылки (только для записи)",
                    "type": "string",
                    "title": "IdOrNameString"
                  }
                ]
              },
              "assignee": {
                "description": "Исполнитель задачи",
                "oneOf": [
                  {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string",
                        "description": "Идентификатор ссылки",
                        "example": "0193dde1-d10b-7c3a-a0eb-4a0ba0319908"
                      },
                      "name": {
                        "type": "string",
                        "description": "Имя",
                        "example": "Масков И.Р."
                      }
                    },
                    "title": "UserRefDto"
                  },
                  {
                    "writeOnly": true,
                    "description": "id или name ссылки (только для записи)",
                    "type": "string",
                    "title": "IdOrNameString"
                  }
                ]
              },
              "release": {
                "description": "Релиз, в который включена задача",
                "oneOf": [
                  {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string",
                        "description": "Идентификатор ссылки",
                        "example": "0193dde1-d10b-7c3a-a0eb-4a0ba0319908"
                      },
                      "name": {
                        "type": "string",
                        "description": "Наименование"
                      }
                    },
                    "title": "CatalogRefDto"
                  },
                  {
                    "writeOnly": true,
                    "description": "id или name ссылки (только для записи)",
                    "type": "string",
                    "title": "IdOrNameString"
                  }
                ]
              },
              "target-branch": {
                "description": "Релизная или основная ветка для заливки результата",
                "oneOf": [
                  {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string",
                        "description": "Идентификатор ссылки",
                        "example": "0193dde1-d10b-7c3a-a0eb-4a0ba0319908"
                      },
                      "name": {
                        "type": "string",
                        "description": "Имя",
                        "example": "issue/CRM-1"
                      },
                      "application": {
                        "type": "object",
                        "description": "Приложение",
                        "properties": {
                          "id": {
                            "type": "string",
                            "description": "Идентификатор ссылки",
                            "example": "0193dde1-d10b-7c3a-a0eb-4a0ba0319908"
                          },
                          "name": {
                            "type": "string",
                            "description": "Название",
                            "example": "CRM-dev"
                          },
                          "url": {
                            "type": "string",
                            "description": "URL",
                            "example": "http://127.0.0.1:9090/applications/CRM-dev"
                          }
                        },
                        "title": "ApplicationRefDto"
                      }
                    },
                    "title": "BranchRefDto"
                  },
                  {
                    "writeOnly": true,
                    "description": "id или name ссылки (только для записи)",
                    "type": "string",
                    "title": "IdOrNameString"
                  }
                ]
              },
              "branch-usage": {
                "description": "Режим выбора ветки разработки",
                "type": "string",
                "enum": [
                  "create-new-branch",
                  "use-main-branch",
                  "choose-branch"
                ],
                "default": "create-new-branch или use-main-branch (в зависимости от настроек проекта)",
                "example": "create-new-branch"
              },
              "branches": {
                "description": "Ветки",
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string",
                      "description": "Идентификатор ссылки",
                      "example": "0193dde1-d10b-7c3a-a0eb-4a0ba0319908"
                    },
                    "name": {
                      "type": "string",
                      "description": "Имя",
                      "example": "issue/CRM-1"
                    },
                    "application": {
                      "type": "object",
                      "description": "Приложение",
                      "properties": {
                        "id": {
                          "type": "string",
                          "description": "Идентификатор ссылки",
                          "example": "0193dde1-d10b-7c3a-a0eb-4a0ba0319908"
                        },
                        "name": {
                          "type": "string",
                          "description": "Название",
                          "example": "CRM-dev"
                        },
                        "url": {
                          "type": "string",
                          "description": "URL",
                          "example": "http://127.0.0.1:9090/applications/CRM-dev"
                        }
                      },
                      "title": "ApplicationRefDto"
                    }
                  },
                  "title": "BranchRefDto"
                }
              },
              "attachments": {
                "description": "Вложения (прикрепленные файлы). В свойствах задачи выгружается только описание. Само тело файла необходимо передавать отдельно (.../issues/{key}/attachment). Вместо тела файла можно заполнить URL ресурса для гиперссылки из формы задачи.",
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": {
                      "type": "string",
                      "description": "Имя файла",
                      "required": true,
                      "example": "Скриншот.jpg"
                    },
                    "size": {
                      "type": "string",
                      "description": "Строковое представление размера",
                      "example": "100,5 КБ"
                    },
                    "url": {
                      "type": "string",
                      "description": "URL адрес для открытия по гиперссылке",
                      "example": "http://1Cbase/files/0193dde1-d10b-7c3a-a0eb-4a0ba0319908"
                    }
                  }
                }
              },
              "labels": {
                "description": "Метки (тэги)",
                "type": "array",
                "items": {
                  "type": "string",
                  "example": "Блок Контрагенты"
                }
              },
              "reviewers": {
                "description": "Проверяющие задачи",
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "user": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "string",
                          "description": "Идентификатор ссылки",
                          "example": "0193dde1-d10b-7c3a-a0eb-4a0ba0319908"
                        },
                        "name": {
                          "type": "string",
                          "description": "Имя",
                          "example": "Масков И.Р."
                        }
                      },
                      "title": "UserRefDto"
                    },
                    "state": {
                      "type": "string",
                      "description": "Результат проверки",
                      "enum": [
                        "not-approved",
                        "approved",
                        "needs-work"
                      ],
                      "default": "not-approved",
                      "example": "approved"
                    }
                  }
                }
              },
              "deletion-mark": {
                "description": "Пометка удаления",
                "type": "boolean",
                "default": false,
                "example": false
              },
              "version-stamp": {
                "description": "Идентификатор версии объекта. Если заполнено в теле запроса изменения объекта - выполняется оптимистическая блокировка.",
                "type": "string",
                "format": "uuid",
                "example": "0193dde1-d10b-7c3a-a0eb-4a0ba0319908"
              },
              "time-stamp": {
                "description": "Отметка времени изменения объекта (при использовании настройки регистрации изменений для задач). Если заполнено в теле запроса изменения объекта - выполняется оптимистическая блокировка.",
                "type": "string",
                "format": "instant",
                "default": "текущая дата",
                "example": "2025-01-02T10:11:12.345Z"
              },
              "write-parameters": {
                "writeOnly": true,
                "description": "Дополнительные действия после записи задачи. Аналогичны командам пользовательского интерфейса. Доступны при создании, изменении, удалении. Выполняются после фиксации транзакции записи объекта. Для вызова необходимо установить значение true для соответствующих атрибутов или передать имена атрибутов в массиве.",
                "type": "object",
                "properties": {
                  "create-single-branch": {
                    "description": "Создать ветку разработки, если ещё нет. С учетом настройки \"branch-usage\".",
                    "type": "boolean"
                  },
                  "set-branch-application": {
                    "allOf": [
                      {
                        "description": "Установить приложение разработки. Если ветка ещё не создана - выполняется \"create-single-branch\"."
                      },
                      {
                        "type": "object",
                        "description": "Приложение",
                        "properties": {
                          "id": {
                            "type": "string",
                            "description": "Идентификатор ссылки",
                            "example": "0193dde1-d10b-7c3a-a0eb-4a0ba0319908"
                          },
                          "name": {
                            "type": "string",
                            "description": "Название",
                            "example": "CRM-dev"
                          },
                          "url": {
                            "type": "string",
                            "description": "URL",
                            "example": "http://127.0.0.1:9090/applications/CRM-dev"
                          }
                        },
                        "title": "ApplicationRefDto"
                      }
                    ]
                  },
                  "merge-branches": {
                    "description": "Включает ветки разработки задачи в основную или релизную ветку, если заполнена.",
                    "type": "boolean"
                  },
                  "update-target-branch-application": {
                    "description": "Обновить приложение целевой ветки (после merge-branches).",
                    "type": "boolean"
                  },
                  "cherry-pick-branch-to": {
                    "allOf": [
                      {
                        "description": "Скопировать изменения из основной ветки разработки задачи в указанную ветку."
                      },
                      {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string",
                            "description": "Идентификатор ссылки",
                            "example": "0193dde1-d10b-7c3a-a0eb-4a0ba0319908"
                          },
                          "name": {
                            "type": "string",
                            "description": "Имя",
                            "example": "issue/CRM-1"
                          },
                          "application": {
                            "type": "object",
                            "description": "Приложение",
                            "properties": {
                              "id": {
                                "type": "string",
                                "description": "Идентификатор ссылки",
                                "example": "0193dde1-d10b-7c3a-a0eb-4a0ba0319908"
                              },
                              "name": {
                                "type": "string",
                                "description": "Название",
                                "example": "CRM-dev"
                              },
                              "url": {
                                "type": "string",
                                "description": "URL",
                                "example": "http://127.0.0.1:9090/applications/CRM-dev"
                              }
                            },
                            "title": "ApplicationRefDto"
                          }
                        },
                        "title": "BranchRefDto"
                      }
                    ]
                  },
                  "delete-branches": {
                    "description": "Удалить ветки разработки задачи.",
                    "type": "boolean"
                  },
                  "delete-branches-applications": {
                    "description": "Удалить приложения веток разработки задачи.",
                    "type": "boolean"
                  },
                  "clear-branches": {
                    "description": "Очистить ссылки на ветки в задаче (без удаления самих веток и их содержимого).",
                    "type": "boolean"
                  }
                }
              }
            },
            "title": "IssueDto"
          }
        }
      }
    },
    "responses": {
      "201": {
        "description": "Новая задача успешно создана. Можно изменить атрибуты ответа через параметры include/exclude.",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "description": "Атрибуты задачи",
              "properties": {
                "id": {
                  "type": "string",
                  "description": "Идентификатор",
                  "example": "0193dde1-d10b-7c3a-a0eb-4a0ba0319908"
                },
                "number": {
                  "description": "Номер",
                  "type": "string",
                  "maxLength": 30,
                  "example": "CRM-1"
                },
                "version-stamp": {
                  "description": "Идентификатор версии объекта",
                  "type": "string",
                  "format": "uuid",
                  "example": "0193dde1-d10b-7c3a-a0eb-4a0ba0319908"
                }
              },
              "title": "IssueResultDto"
            }
          }
        }
      },
      "205": {
        "description": "Найдена уже созданная задача, по указанным параметрам поиска. Выгружаются её данные без изменения. Можно изменить атрибуты ответа через параметры include/exclude.",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "description": "Атрибуты задачи",
              "properties": {
                "id": {
                  "type": "string",
                  "description": "Идентификатор",
                  "example": "0193dde1-d10b-7c3a-a0eb-4a0ba0319908"
                },
                "number": {
                  "description": "Номер",
                  "type": "string",
                  "maxLength": 30,
                  "example": "CRM-1"
                },
                "version-stamp": {
                  "description": "Идентификатор версии объекта",
                  "type": "string",
                  "format": "uuid",
                  "example": "0193dde1-d10b-7c3a-a0eb-4a0ba0319908"
                }
              },
              "title": "IssueResultDto"
            }
          }
        }
